from pydantic import BaseModel


class RefundRequest(BaseModel):
    transaction_id: str
    merchant_id: str
    refund_type: str
    refund_amount: float


class RefundResponse(BaseModel):
    message: str
    refund_status: str

//strategies.py//
class RefundStrategy:

    def execute(self, request):
        raise NotImplementedError


class FullRefundBeforeInstallment(RefundStrategy):

    def execute(self, request):
        print("Cancelling BNPL loan")
        print("Restoring credit limit")
        print("Initiating settlement recovery")


class FullRefundAfterPayment(RefundStrategy):

    def execute(self, request):
        print("Refunding customer payments")
        print("Cancelling remaining installments")


class PartialRefundStrategy(RefundStrategy):

    def execute(self, request):
        print("Recalculating loan principal")
        print("Adjusting installment schedule")
