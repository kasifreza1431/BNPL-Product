def publish_refund_event(refund_id, transaction_id):

    event = {
        "refund_id": refund_id,
        "transaction_id": transaction_id,
        "event_type": "REFUND_CREATED"
    }

    print("Publishing Event:", event)


//service.py//
from strategies import (
    FullRefundBeforeInstallment,
    FullRefundAfterPayment,
    PartialRefundStrategy
)


class RefundService:

    def get_strategy(self, refund_type):

        if refund_type == "FULL_BEFORE_INSTALLMENT":
            return FullRefundBeforeInstallment()

        elif refund_type == "FULL_AFTER_PAYMENT":
            return FullRefundAfterPayment()

        else:
            return PartialRefundStrategy()

    def process_refund(self, request):

        strategy = self.get_strategy(request.refund_type)

        strategy.execute(request)

        return {
            "message": "Refund processed successfully",
            "refund_status": "COMPLETED"
        }

//main.py//

from fastapi import FastAPI, Depends
from sqlalchemy.orm import Session
from database import Base, engine, SessionLocal
from schemas import RefundRequest, RefundResponse
from models import RefundTransaction
from service import RefundService
from events import publish_refund_event


Base.metadata.create_all(bind=engine)

app = FastAPI(title="BNPL Refund Service")

refund_service = RefundService()


def get_db():
    db = SessionLocal()
    try:
        yield db
    finally:
        db.close()


@app.post("/refunds", response_model=RefundResponse)
def create_refund(request: RefundRequest, db: Session = Depends(get_db)):

    refund = RefundTransaction(
        transaction_id=request.transaction_id,
        merchant_id=request.merchant_id,
        refund_type=request.refund_type,
        refund_amount=request.refund_amount,
        refund_status="PROCESSING"
    )

    db.add(refund)
    db.commit()
    db.refresh(refund)

    result = refund_service.process_refund(request)

    refund.refund_status = "COMPLETED"
    db.commit()

    publish_refund_event(refund.id, request.transaction_id)

    return result

